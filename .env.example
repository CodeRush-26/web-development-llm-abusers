# Copy to `.env` in this folder (repo root) for local dev.
# Get a free Groq API key: https://console.groq.com/

# Required for LLM distress analysis (optional — server falls back to heuristics if empty)
GROQ_API_KEY=

# Groq chat model (OpenAI-compatible API). Examples: llama-3.3-70b-versatile, llama-3.1-8b-instant
GROQ_MODEL=llama-3.3-70b-versatile

# API + WebSocket (apps/server)
PORT=4000

# Browser → fleet API (HTTP + Socket.IO). Optional for local dev:
# when unset, the UI resolves automatically — localhost → http://localhost:4000;
# *.hf.space → same origin; other hosts → http(s)://<hostname>:4000 (LAN).
# Set explicitly when the API is on another host (e.g. Next on Vercel, API on Hugging Face):
# NEXT_PUBLIC_WS_URL=https://your-space.hf.space
NEXT_PUBLIC_WS_URL=
